# =============================================================================
# MILITARY PASS — Docker build context exclusions
# =============================================================================

# dependencies (reinstalled inside the image)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js build output (regenerated inside the image)
.next
out
build

# secrets — NEVER bake env files into the image; use HF Space Secrets/Variables
.env
.env*
!.env.local.example

# git & IDE
.git
.gitignore
.github
.vscode
.idea
.claude
.agents

# vercel / other platform configs (irrelevant to the HF Docker build)
.vercel
apphosting.yaml
railway.json
render.yaml
nixpacks.toml

# tests, docs, misc
tests
docs
coverage
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.DS_Store
*.md
!README.md
modal_login.png
